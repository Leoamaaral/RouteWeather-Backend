APP_NAME=RouteWeather
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_STORE=file
# Para Redis (performance): CACHE_STORE=redis + extensão phpredis ou predis
QUEUE_CONNECTION=sync

# CORS: origens do Next.js (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000

GOOGLE_MAPS_API_KEY=
TOMORROW_IO_API_KEY=
TOMORROW_IO_BASE_URL=https://api.tomorrow.io/v4

# Idioma da geocodificação reversa das cidades dos pontos amostrados
GEOCODE_LANGUAGE=pt-BR

ROUTE_SAMPLE_INTERVAL_KM=25
ROUTE_SAMPLE_MIN_POINTS=3
ROUTE_SAMPLE_MAX_POINTS=24
WEATHER_CACHE_TTL=900
WEATHER_CACHE_LATLNG_ROUND=2

# Cache do plano completo (segundos); 0 desativa
PLAN_CACHE_TTL=300
# Máximo de janelas comparadas em /plan/compare
ROUTE_COMPARE_MAX_WINDOWS=6

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
